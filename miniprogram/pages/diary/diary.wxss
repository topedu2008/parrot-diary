/* 日记列表页面样式 */

/* 顶部操作栏 */
.header {
  padding: 16px;
  background: var(--card-color);
  margin-bottom: 12px;
}

.header-title {
  font-size: 20px;
  font-weight: bold;
}

.write-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 16px;
  background: var(--primary-color);
  color: white;
  border-radius: 20px;
  font-size: 14px;
}

.btn-icon {
  font-size: 16px;
}

/* 心情筛选 */
.mood-filter {
  background: var(--card-color);
  padding: 12px 0;
  margin-bottom: 12px;
}

.scroll-view {
  white-space: nowrap;
}

.mood-item {
  display: inline-block;
  padding: 8px 16px;
  margin: 0 4px;
  border-radius: 24px;
  font-size: 24px;
  background: var(--bg-color);
}

.mood-item.active {
  background: var(--primary-color);
  transform: scale(1.1);
}

/* 日记列表 */
.diary-list {
  padding: 0 16px 16px;
}

.diary-item {
  margin-bottom: 16px;
}

.diary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.diary-date {
  display: flex;
  flex-direction: column;
}

.date-day {
  font-size: 18px;
  font-weight: bold;
  color: var(--primary-color);
}

.date-weekday {
  font-size: 12px;
  color: var(--text-secondary);
}

.diary-mood {
  font-size: 32px;
}

.diary-content {
  margin-bottom: 12px;
}

.diary-text {
  display: block;
  font-size: 15px;
  color: var(--text-primary);
  line-height: 1.8;
  margin-bottom: 12px;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.diary-images {
  margin-top: 12px;
}

.diary-image {
  width: 100%;
  height: 200px;
  border-radius: 8px;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
}

.diary-image-small {
  width: 100%;
  height: 100px;
  border-radius: 8px;
}

.image-more {
  position: relative;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.more-text {
  color: white;
  font-size: 16px;
  font-weight: bold;
}

.diary-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 12px;
  border-top: 1px solid var(--border-color);
}

.diary-tags {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.tag {
  font-size: 12px;
  color: var(--primary-color);
}

.diary-stats {
  display: flex;
  gap: 12px;
  font-size: 12px;
  color: var(--text-hint);
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 4px;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 20px;
  color: var(--text-secondary);
  font-size: 14px;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80px 20px;
}

.empty-icon {
  font-size: 80px;
  display: block;
  margin-bottom: 16px;
}

.empty-title {
  font-size: 18px;
  font-weight: bold;
  display: block;
  margin-bottom: 8px;
}

.empty-desc {
  font-size: 14px;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 24px;
}
