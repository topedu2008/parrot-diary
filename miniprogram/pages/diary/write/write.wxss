/* 写日记页面样式 */

/* 选择器卡片 */
.parrot-selector,
.mood-selector,
.content-editor,
.photo-uploader,
.tag-editor,
.privacy-setting {
  margin-bottom: 12px;
}

.selector-label,
.editor-label,
.uploader-label,
.setting-label {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 12px;
}

.selector-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 16px;
  color: var(--text-primary);
}

.arrow {
  font-size: 20px;
  color: var(--text-hint);
}

/* 心情选项 */
.mood-options {
  display: flex;
  justify-content: space-between;
  gap: 8px;
}

.mood-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  padding: 12px 8px;
  border-radius: 12px;
  background: var(--bg-color);
  flex: 1;
}

.mood-option.selected {
  background: var(--primary-color);
}

.mood-emoji {
  font-size: 32px;
}

.mood-label {
  font-size: 12px;
  color: var(--text-secondary);
}

.mood-option.selected .mood-label {
  color: white;
}

/* 编辑器 */
.editor-input {
  width: 100%;
  min-height: 150px;
  font-size: 15px;
  line-height: 1.8;
  border: none;
  background: transparent;
}

.char-count {
  text-align: right;
  font-size: 12px;
  color: var(--text-hint);
  margin-top: 8px;
}

/* 照片上传 */
.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}

.photo-item {
  position: relative;
  aspect-ratio: 1;
  border-radius: 8px;
  overflow: hidden;
}

.photo-thumb {
  width: 100%;
  height: 100%;
}

.photo-delete {
  position: absolute;
  top: 4px;
  right: 4px;
  width: 24px;
  height: 24px;
  background: rgba(0, 0, 0, 0.6);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
}

.photo-add {
  aspect-ratio: 1;
  border-radius: 8px;
  background: var(--bg-color);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  border: 2px dashed var(--border-color);
}

.add-icon {
  font-size: 32px;
}

.add-text {
  font-size: 12px;
  color: var(--text-hint);
}

/* 标签编辑器 */
.tag-input-wrapper {
  margin-bottom: 12px;
}

.tag-input {
  width: 100%;
  padding: 12px;
  border-radius: 8px;
  background: var(--bg-color);
  font-size: 14px;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 12px;
}

.tag-item {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 6px 12px;
  background: var(--primary-color);
  color: white;
  border-radius: 16px;
  font-size: 13px;
}

.tag-delete {
  font-size: 14px;
  opacity: 0.8;
}

.tag-suggestions {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.tag-suggestion {
  padding: 6px 12px;
  background: var(--bg-color);
  color: var(--primary-color);
  border-radius: 16px;
  font-size: 13px;
}

/* 隐私设置 */
.setting-options {
  display: flex;
  gap: 12px;
}

.setting-option {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px;
  border-radius: 8px;
  background: var(--bg-color);
  border: 2px solid transparent;
}

.setting-option.selected {
  background: var(--primary-color);
  border-color: var(--primary-color);
}

.setting-option.selected .option-text {
  color: white;
}

.option-icon {
  font-size: 20px;
}

.option-text {
  font-size: 14px;
  color: var(--text-secondary);
}

/* 发布区域 */
.publish-section {
  padding: 16px;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--card-color);
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.1);
}

.btn-block[disabled] {
  opacity: 0.5;
}
