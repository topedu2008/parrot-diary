/* 首页样式 */

/* 欢迎区 */
.welcome-section {
  padding: 20px 0;
}

.welcome-title {
  font-size: 24px;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 8px;
}

.welcome-desc {
  font-size: 14px;
  color: var(--text-secondary);
}

/* 鹦鹉卡片 */
.parrot-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.parrot-header {
  margin-bottom: 16px;
}

.parrot-name {
  font-size: 20px;
  font-weight: bold;
}

.parrot-avatar {
  height: 100px;
  margin-bottom: 16px;
}

.avatar-emoji {
  font-size: 80px;
}

.parrot-info {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12px;
  padding: 16px;
}

.info-item {
  flex: 1;
}

.info-number {
  display: block;
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 4px;
}

.info-label {
  display: block;
  font-size: 12px;
  opacity: 0.9;
}

.add-parrot {
  min-height: 300px;
}

/* 快捷操作 */
.section-title {
  font-size: 18px;
  font-weight: bold;
  margin: 24px 0 12px;
  color: var(--text-primary);
}

.quick-actions {
  display: flex;
  gap: 12px;
}

.action-btn {
  flex: 1;
  flex-direction: column;
  padding: 24px 16px;
}

.action-icon-large {
  font-size: 48px;
  margin-bottom: 8px;
}

.action-text {
  font-size: 14px;
  color: var(--text-secondary);
}

/* 导航提示 */
.nav-hint {
  margin-top: 12px;
}

.hint-title {
  font-size: 16px;
  font-weight: bold;
  margin-bottom: 12px;
  color: var(--primary-color);
}

.hint-grid {
  display: flex;
  justify-content: space-around;
  padding: 12px 0;
}

.hint-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.hint-icon {
  font-size: 32px;
}

.hint-text {
  font-size: 13px;
  color: var(--text-secondary);
}

.hint-desc {
  text-align: center;
  font-size: 12px;
  color: var(--text-hint);
  margin-top: 12px;
}

/* 照片相关 */
.more-link {
  font-size: 14px;
  color: var(--primary-color);
}

.photo-item {
  aspect-ratio: 1;
  border-radius: 8px;
  overflow: hidden;
}

.photo-thumb {
  width: 100%;
  height: 100%;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60px 20px;
}

.empty-icon {
  font-size: 64px;
  margin-bottom: 16px;
}

.empty-title {
  font-size: 18px;
  font-weight: bold;
  margin-bottom: 8px;
}

.empty-desc {
  font-size: 14px;
  color: var(--text-secondary);
  margin-bottom: 24px;
}

/* 工具类 */
.mt-4 {
  margin-top: 16px;
}
