/* 首页样式 */

/* 欢迎区 */
.welcome-section {
  padding: 20px 0;
}

.welcome-title {
  font-size: 24px;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 8px;
}

.welcome-desc {
  font-size: 14px;
  color: var(--text-secondary);
}

/* 鹦鹉卡片 */
.parrot-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  margin-bottom: 16px;
}

.parrot-header {
  margin-bottom: 16px;
}

.parrot-name {
  font-size: 20px;
  font-weight: bold;
}

.parrot-avatar {
  height: 100px;
  margin-bottom: 16px;
}

.avatar-emoji {
  font-size: 80px;
}

.parrot-info {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12px;
  padding: 16px;
}

.info-item {
  flex: 1;
}

.info-number {
  display: block;
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 4px;
}

.info-label {
  display: block;
  font-size: 12px;
  opacity: 0.9;
}

.add-parrot {
  min-height: 300px;
  margin-bottom: 16px;
}

/* 成长统计 */
.section-title {
  font-size: 18px;
  font-weight: bold;
  margin: 24px 0 12px;
  color: var(--text-primary);
}

.stats-grid {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 20px;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}

.stat-icon {
  font-size: 24px;
  margin-bottom: 4px;
}

.stat-value {
  font-size: 24px;
  font-weight: bold;
  color: var(--primary-color);
}

.stat-label {
  font-size: 12px;
  color: var(--text-secondary);
}

.stat-divider-vertical {
  width: 1px;
  height: 50px;
  background: var(--border-color);
}

/* 最近照片 */
.recent-photos {
  padding: 0;
  overflow: hidden;
}

.photo-carousel {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
  padding: 16px;
}

.photo-item {
  position: relative;
  aspect-ratio: 1;
  border-radius: 8px;
  overflow: hidden;
}

.photo-thumb {
  width: 100%;
  height: 100%;
}

.photo-date {
  position: absolute;
  bottom: 4px;
  right: 4px;
  background: rgba(0, 0, 0, 0.6);
  color: white;
  padding: 2px 6px;
  border-radius: 4px;
  font-size: 10px;
}

/* 最新日记 */
.latest-diary {
  padding: 16px;
}

.diary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.diary-mood {
  font-size: 28px;
}

.diary-date {
  font-size: 13px;
  color: var(--text-hint);
}

.diary-content {
  font-size: 14px;
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 12px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.diary-images {
  position: relative;
  width: 100%;
  height: 150px;
  border-radius: 8px;
  overflow: hidden;
}

.diary-image {
  width: 100%;
  height: 100%;
}

.image-count {
  position: absolute;
  bottom: 8px;
  right: 8px;
  background: rgba(0, 0, 0, 0.6);
  color: white;
  padding: 4px 8px;
  border-radius: 4px;
  font-size: 12px;
}

/* 技能获得 */
.skills-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  padding: 16px;
}

.skill-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}

.skill-icon {
  font-size: 32px;
}

.skill-name {
  font-size: 12px;
  color: var(--text-primary);
  text-align: center;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.skill-date {
  font-size: 11px;
  color: var(--text-hint);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60px 20px;
}

.empty-icon {
  font-size: 64px;
  display: block;
  margin-bottom: 16px;
}

.empty-title {
  font-size: 18px;
  font-weight: bold;
  display: block;
  margin-bottom: 8px;
}

.empty-desc {
  font-size: 14px;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 24px;
}

/* 工具类 */
.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.more-link {
  font-size: 14px;
  color: var(--primary-color);
}

.mt-4 {
  margin-top: 16px;
}
