<!--首页 - 鹦鹉成长日记-->
<view class="container">
  <!-- 顶部欢迎区 -->
  <view class="welcome-section">
    <view class="welcome-title">你好，鹦鹉主人 👋</view>
    <view class="welcome-desc">记录鹦鹉成长的每一刻美好</view>
  </view>

  <!-- 鹦鹉卡片 -->
  <view class="parrot-card card" wx:if="{{currentParrot}}" bindtap="goToParrot">
    <view class="parrot-header flex-between">
      <view class="parrot-name">{{currentParrot.name}}</view>
      <view class="tag">{{currentParrot.breed}}</view>
    </view>
    <view class="parrot-avatar flex-center">
      <text class="avatar-emoji">🦜</text>
    </view>
    <view class="parrot-info flex-between">
      <view class="info-item text-center">
        <text class="info-number">{{stats.days}}</text>
        <text class="info-label">饲养天数</text>
      </view>
      <view class="info-item text-center">
        <text class="info-number">{{stats.photos}}</text>
        <text class="info-label">照片</text>
      </view>
      <view class="info-item text-center">
        <text class="info-number">{{stats.trainings}}</text>
        <text class="info-label">训练</text>
      </view>
    </view>
  </view>

  <!-- 添加鹦鹉 -->
  <view class="add-parrot card" wx:else bindtap="addParrot">
    <view class="empty-state">
      <text class="empty-icon">🦜</text>
      <text class="empty-title">还没有鹦鹉档案</text>
      <text class="empty-desc">创建第一个鹦鹉档案，开始记录成长</text>
      <button class="btn btn-primary">添加鹦鹉</button>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="section-title">快速记录</view>
  <view class="quick-actions flex">
    <view class="action-btn card flex-center" bindtap="takePhoto">
      <text class="action-icon-large">📷</text>
      <text class="action-text">拍照</text>
    </view>
    <view class="action-btn card flex-center" bindtap="writeDiary">
      <text class="action-icon-large">📝</text>
      <text class="action-text">日记</text>
    </view>
    <view class="action-btn card flex-center" bindtap="viewStats">
      <text class="action-icon-large">📊</text>
      <text class="action-text">统计</text>
    </view>
  </view>

  <!-- 导航提示 -->
  <view class="nav-hint card">
    <view class="hint-title">💡 更多功能</view>
    <view class="hint-grid">
      <view class="hint-item">
        <text class="hint-icon">📷</text>
        <text class="hint-text">相册</text>
      </view>
      <view class="hint-item">
        <text class="hint-icon">📖</text>
        <text class="hint-text">饲养指南</text>
      </view>
      <view class="hint-item">
        <text class="hint-icon">🎵</text>
        <text class="hint-text">音频训练</text>
      </view>
    </view>
    <view class="hint-desc">点击下方导航栏访问</view>
  </view>

  <!-- 最近照片 -->
  <view class="section-title flex-between">
    <text>最近照片</text>
    <text class="more-link" bindtap="goToAlbum">查看更多 ></text>
  </view>
  <view class="recent-photos grid-3" wx:if="{{recentPhotos.length > 0}}">
    <view class="photo-item" wx:for="{{recentPhotos}}" wx:key="id" bindtap="previewPhoto" data-url="{{item.path}}">
      <image class="photo-thumb" src="{{item.path}}" mode="aspectFill" />
    </view>
  </view>
  <view class="empty-state" wx:else>
    <text class="empty-icon">📷</text>
    <text class="empty-desc">还没有照片，快去拍一张吧</text>
    <button class="btn btn-primary mt-4" bindtap="takePhoto">拍摄第一张照片</button>
  </view>

  <!-- 底部留白（避免被 tabBar 遮挡） -->
  <view style="height: 100px;"></view>
</view>
