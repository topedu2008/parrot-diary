<!--首页 - 鹦鹉成长日记-->
<view class="container">
  <!-- 顶部欢迎区 -->
  <view class="welcome-section">
    <view class="welcome-title">你好，鹦鹉主人 👋</view>
    <view class="welcome-desc">记录鹦鹉成长的每一刻美好</view>
  </view>

  <!-- 鹦鹉卡片 -->
  <view class="parrot-card card" wx:if="{{currentParrot}}" bindtap="goToParrot">
    <view class="parrot-header flex-between">
      <view class="parrot-name">{{currentParrot.name}}</view>
      <view class="tag">{{currentParrot.breed}}</view>
    </view>
    <view class="parrot-avatar flex-center">
      <text class="avatar-emoji">🦜</text>
    </view>
    <view class="parrot-info flex-between">
      <view class="info-item text-center">
        <text class="info-number">{{stats.days}}</text>
        <text class="info-label">饲养天数</text>
      </view>
      <view class="info-item text-center">
        <text class="info-number">{{stats.photos}}</text>
        <text class="info-label">照片</text>
      </view>
      <view class="info-item text-center">
        <text class="info-number">{{stats.trainings}}</text>
        <text class="info-label">训练</text>
      </view>
    </view>
  </view>

  <!-- 添加鹦鹉 -->
  <view class="add-parrot card" wx:else bindtap="addParrot">
    <view class="empty-state">
      <text class="empty-icon">🦜</text>
      <text class="empty-title">还没有鹦鹉档案</text>
      <text class="empty-desc">创建第一个鹦鹉档案，开始记录成长</text>
      <button class="btn btn-primary">添加鹦鹉</button>
    </view>
  </view>

  <!-- 成长统计 -->
  <view class="section-title">成长统计</view>
  <view class="stats-grid card" wx:if="{{currentParrot}}">
    <view class="stat-item">
      <view class="stat-icon">📷</view>
      <view class="stat-value">{{stats.photos}}</view>
      <view class="stat-label">照片</view>
    </view>
    <view class="stat-divider-vertical"></view>
    <view class="stat-item">
      <view class="stat-icon">📝</view>
      <view class="stat-value">{{stats.diaries}}</view>
      <view class="stat-label">日记</view>
    </view>
    <view class="stat-divider-vertical"></view>
    <view class="stat-item">
      <view class="stat-icon">🎵</view>
      <view class="stat-value">{{stats.trainings}}</view>
      <view class="stat-label">技能</view>
    </view>
    <view class="stat-divider-vertical"></view>
    <view class="stat-item">
      <view class="stat-icon">⚖️</view>
      <view class="stat-value">{{stats.weight || '--'}}</view>
      <view class="stat-label">体重 (g)</view>
    </view>
  </view>

  <!-- 最新照片 -->
  <view class="section-title flex-between">
    <text>📸 最新照片</text>
    <text class="more-link" bindtap="goToAlbum">查看全部 ></text>
  </view>
  <view class="recent-photos card" wx:if="{{recentPhotos.length > 0}}">
    <view class="photo-carousel">
      <view class="photo-item" wx:for="{{recentPhotos}}" wx:key="id" wx:if="{{index < 4}}" bindtap="previewPhoto" data-url="{{item.path}}">
        <image class="photo-thumb" src="{{item.path}}" mode="aspectFill" />
        <view class="photo-date">{{item.date}}</view>
      </view>
    </view>
  </view>
  <view class="empty-state card" wx:else>
    <text class="empty-icon">📷</text>
    <text class="empty-desc">还没有照片，记录第一个瞬间吧</text>
  </view>

  <!-- 最新日记 -->
  <view class="section-title flex-between" wx:if="{{latestDiary}}">
    <text>📝 最新日记</text>
    <text class="more-link" bindtap="goToDiary">查看全部 ></text>
  </view>
  <view class="latest-diary card" wx:if="{{latestDiary}}" bindtap="viewDiaryDetail" data-id="{{latestDiary.id}}">
    <view class="diary-header">
      <view class="diary-mood">{{latestDiary.mood}}</view>
      <view class="diary-date">{{latestDiary.date}}</view>
    </view>
    <view class="diary-content">{{latestDiary.content}}</view>
    <view class="diary-images" wx:if="{{latestDiary.images && latestDiary.images.length > 0}}">
      <image class="diary-image" src="{{latestDiary.images[0]}}" mode="aspectFill" />
      <view class="image-count" wx:if="{{latestDiary.images.length > 1}}">+{{latestDiary.images.length - 1}}</view>
    </view>
  </view>

  <!-- 技能获得 -->
  <view class="section-title" wx:if="{{skills.length > 0}}">
    <text>🎯 技能获得</text>
  </view>
  <view class="skills-grid card" wx:if="{{skills.length > 0}}">
    <view class="skill-item" wx:for="{{skills}}" wx:key="id">
      <view class="skill-icon">{{item.icon}}</view>
      <view class="skill-name">{{item.name}}</view>
      <view class="skill-date">{{item.date}}</view>
    </view>
  </view>

  <!-- 底部留白（避免被 tabBar 遮挡） -->
  <view style="height: 100px;"></view>
</view>
