/* 音频训练页面样式 */

/* 搜索栏 */
.search-bar {
  padding: 16px;
  background: var(--card-color);
  margin-bottom: 12px;
}

.search-input {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 16px;
  background: var(--bg-color);
  border-radius: 24px;
  font-size: 14px;
  color: var(--text-hint);
}

.search-icon {
  font-size: 16px;
}

/* 分类滚动 */
.category-scroll {
  background: var(--card-color);
  padding: 12px 0;
  margin-bottom: 12px;
}

.scroll-view {
  white-space: nowrap;
}

.category-item {
  display: inline-block;
  padding: 8px 16px;
  margin: 0 4px;
  border-radius: 20px;
  font-size: 14px;
  color: var(--text-secondary);
  background: var(--bg-color);
}

.category-item.active {
  background: var(--primary-color);
  color: white;
}

/* 进度卡片 */
.progress-card {
  margin: 12px 16px;
}

.progress-title {
  font-size: 16px;
  font-weight: bold;
  margin-bottom: 16px;
}

.progress-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 16px;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.stat-number {
  font-size: 24px;
  font-weight: bold;
  color: var(--primary-color);
}

.stat-label {
  font-size: 12px;
  color: var(--text-secondary);
}

.progress-bar {
  height: 8px;
  background: var(--bg-color);
  border-radius: 4px;
  overflow: hidden;
  margin-bottom: 8px;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4CAF50, #8BC34A);
  border-radius: 4px;
  transition: width 0.3s;
}

.progress-text {
  text-align: center;
  font-size: 12px;
  color: var(--text-secondary);
}

/* 区块标题 */
.section-title {
  font-size: 18px;
  font-weight: bold;
  padding: 16px 16px 12px;
  color: var(--text-primary);
}

/* 推荐音频列表 */
.recommended-list {
  padding: 0 16px 16px;
}

.audio-card {
  margin-bottom: 12px;
}

.audio-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 12px;
}

.audio-icon {
  font-size: 40px;
  width: 60px;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-color);
  border-radius: 12px;
}

.audio-info {
  flex: 1;
}

.audio-title {
  font-size: 16px;
  font-weight: bold;
  margin-bottom: 6px;
}

.audio-meta {
  display: flex;
  gap: 8px;
  align-items: center;
  font-size: 12px;
}

.audio-level {
  padding: 2px 8px;
  background: #FF9800;
  color: white;
  border-radius: 10px;
  font-size: 11px;
}

.audio-duration {
  color: var(--text-hint);
}

.play-btn {
  width: 50px;
  height: 50px;
  background: var(--primary-color);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
}

.audio-desc {
  font-size: 14px;
  color: var(--text-secondary);
  margin-bottom: 12px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.audio-stats {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  color: var(--text-hint);
}

/* 音频列表 */
.audio-list {
  padding: 0 16px 16px;
}

.audio-item {
  margin-bottom: 12px;
}

.play-btn-small {
  width: 40px;
  height: 40px;
  background: var(--primary-color);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
}

.tag-small {
  padding: 2px 8px;
  font-size: 11px;
  background: var(--primary-color);
  color: white;
  border-radius: 10px;
  margin-right: 8px;
}

/* 底部播放栏 */
.player-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 70px;
  background: var(--card-color);
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
  z-index: 100;
}

.player-info {
  flex: 1;
}

.player-name {
  font-size: 14px;
  font-weight: 500;
  margin-bottom: 4px;
}

.player-status {
  font-size: 12px;
  color: var(--text-secondary);
}

.player-controls {
  display: flex;
  gap: 16px;
}

.control-btn {
  width: 44px;
  height: 44px;
  background: var(--primary-color);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
}

/* 播放详情页 */
.player-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.player-modal.show {
  opacity: 1;
  visibility: visible;
}

.player-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-color);
  border-radius: 24px 24px 0 0;
  max-height: 90vh;
  overflow-y: auto;
  transform: translateY(100%);
  transition: transform 0.3s;
}

.player-modal.show .player-content {
  transform: translateY(0);
}

.player-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  background: var(--card-color);
  border-radius: 24px 24px 0 0;
}

.close-btn,
.more-btn {
  font-size: 24px;
  padding: 8px;
}

.player-title {
  font-size: 18px;
  font-weight: bold;
}

.player-main {
  padding: 24px 20px;
}

.audio-visualizer {
  height: 200px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16px;
  margin-bottom: 24px;
}

.visualizer-icon {
  font-size: 100px;
}

.player-progress {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 24px;
}

.current-time,
.total-time {
  font-size: 12px;
  color: var(--text-secondary);
  min-width: 40px;
}

.progress-slider {
  flex: 1;
}

.player-buttons {
  display: flex;
  justify-content: center;
  margin-bottom: 32px;
}

.play-btn-large {
  width: 80px;
  height: 80px;
  background: var(--primary-color);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
  box-shadow: 0 4px 16px rgba(76, 175, 80, 0.4);
}

.method-title,
.result-title {
  font-size: 16px;
  font-weight: bold;
  margin-bottom: 8px;
  color: var(--primary-color);
}

.method-content,
.result-content {
  font-size: 14px;
  color: var(--text-secondary);
  line-height: 1.8;
}

.stats-info {
  display: flex;
  justify-content: space-around;
  padding: 20px 0;
  margin-bottom: 24px;
}

.stat-value {
  display: block;
  font-size: 20px;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 4px;
}

.stat-desc {
  display: block;
  font-size: 12px;
  color: var(--text-secondary);
}

.btn-block {
  width: 100%;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 20px;
  color: var(--text-secondary);
  font-size: 14px;
}
